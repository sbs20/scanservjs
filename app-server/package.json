{
  "name": "scanservjs-server",
  "version": "3.1.0",
  "description": "scanservjs-api is a REST based API to control your scanner.",
  "scripts": {
    "build": "node build.js",
    "clean": "npm run clean:dist && npm run clean:modules",
    "clean:dist": "rm -rf ./dist",
    "clean:modules": "rm -rf ./node_modules",
    "dev": "nodemon -e js,json,yml src/server.js",
    "lint": "eslint ./src/**/*.js ./config/config.default.js ./test/**/*.js build.js",
    "serve": "node ./src/server.js",
    "test": "mocha"
  },
  "main": "server/server.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/sbs20/scanservjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "fs-extra": "11.3.5",
    "globals": "^17.6.0",
    "mocha": "11.7.6",
    "nodemon": "3.1.14"
  },
  "author": "Sam Strachan",
  "license": "GPL-2.0",
  "engines": {
    "node": ">=12"
  },
  "dependencies": {
    "adm-zip": "0.5.17",
    "cors": "2.8.6",
    "dayjs": "1.11.21",
    "express": "4.22.2",
    "express-basic-auth": "1.2.1",
    "loglevel": "1.9.2",
    "loglevel-plugin-prefix": "0.8.4",
    "mv": "2.1.1",
    "semver": "7.8.1",
    "swagger-jsdoc": "6.2.8",
    "swagger-ui-express": "5.0.1"
  },
  "nodemonConfig": {
    "watch": [
      "server"
    ]
  }
}
