{
  "name": "scanservjs-ui",
  "version": "3.2.0",
  "description": "scanservjs is a simple web-based UI for SANE which allows you to share a scanner on a network without the need for drivers or complicated installation.",
  "author": "Sam Strachan",
  "scripts": {
    "build": "vite build",
    "clean": "npm run clean:dist && npm run clean:modules",
    "clean:dist": "rm -rf ./dist",
    "clean:modules": "rm -rf ./node_modules",
    "dev": "vite",
    "lint": "eslint \"src/**/*.{js,vue}\"",
    "missing-translations": "node missing-translations.js",
    "preview": "vite preview"
  },
  "main": "server/server.js",
  "dependencies": {
    "@intlify/unplugin-vue-i18n": "1.5.0",
    "@mdi/js": "7.4.47",
    "@vitejs/plugin-vue": "6.0.7",
    "vite-plugin-vuetify": "2.1.3",
    "vue": "3.5.35",
    "vue-advanced-cropper": "2.8.9",
    "vue-i18n": "9.14.5",
    "vue-router": "5.1.0",
    "vue-toastr": "3.0.5",
    "vuetify": "4.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "nodemon": "3.1.14",
    "sass": "1.100.0",
    "upath": "3.0.7",
    "vite": "8.0.16"
  },
  "license": "GPL-2.0",
  "nodemonConfig": {
    "watch": [
      "../server/src"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sbs20/scanservjs"
  }
}
